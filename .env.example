# Precision AgriAI Environment Configuration
# Copy this file to .env and fill in your values

# Application Settings
APP_NAME=Precision AgriAI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB Configuration
AWS__DYNAMODB_PLOTS_TABLE=PrecisionAgri_Plots
AWS__DYNAMODB_ALERTS_TABLE=PrecisionAgri_Alerts

# AWS Bedrock Configuration
AWS__BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
AWS__BEDROCK_HAIKU_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# S3 Configuration
AWS__S3_AUDIO_BUCKET=precision-agriai-audio

# SNS Configuration (optional)
AWS__SNS_TOPIC_ARN=

# MapService Configuration
MAP_SERVICE__BHUVAN_BASE_URL=https://bhuvan-vec1.nrsc.gov.in/bhuvan/gwc/service/wms
MAP_SERVICE__BHUVAN_DEFAULT_LAYER=LISS3
# Note: Tuple values are set as defaults in settings.py, no need to override here
# MAP_SERVICE__INDIA_LAT_BOUNDS=(6.0, 37.0)
# MAP_SERVICE__INDIA_LON_BOUNDS=(68.0, 97.0)
MAP_SERVICE__COORDINATE_PRECISION=4

# Google Earth Engine Configuration
GEE__SERVICE_ACCOUNT_EMAIL=
GEE__PRIVATE_KEY_PATH=
GEE__NDVI_COLLECTION=LANDSAT/LC08/C02/T1_L2
GEE__CLOUD_COVER_THRESHOLD=20.0

# Sentinel-2 Configuration
SENTINEL__S3_BUCKET=sentinel-s2-l2a
SENTINEL__DEFAULT_RESOLUTION=60m
SENTINEL__PRESIGNED_URL_EXPIRY=3600

# VoiceService Configuration
VOICE_SERVICE__DEFAULT_LANGUAGE=en-IN
VOICE_SERVICE__TRANSCRIBE_TIMEOUT=30
VOICE_SERVICE__POLLY_VOICE_ID=Aditi
VOICE_SERVICE__AUDIO_FORMAT=mp3

# DbService Configuration
DB_SERVICE__READ_CAPACITY_UNITS=5
DB_SERVICE__WRITE_CAPACITY_UNITS=5
DB_SERVICE__ENABLE_POINT_IN_TIME_RECOVERY=true
DB_SERVICE__ENABLE_ENCRYPTION=true
DB_SERVICE__QUERY_LIMIT=100
DB_SERVICE__BATCH_WRITE_SIZE=25

# BrainService Configuration
BRAIN_SERVICE__MAX_TOKENS=1000
BRAIN_SERVICE__TEMPERATURE=0.7
BRAIN_SERVICE__ENABLE_MULTIMODAL=true
BRAIN_SERVICE__NDVI_THRESHOLD_CRITICAL=0.2
BRAIN_SERVICE__NDVI_THRESHOLD_HIGH=0.3
BRAIN_SERVICE__NDVI_THRESHOLD_MEDIUM=0.5
BRAIN_SERVICE__CLUSTER_OUTBREAK_MIN_PLOTS=3

# Performance Configuration
PERFORMANCE__MAX_RESPONSE_TIME_SECONDS=8
PERFORMANCE__CONCURRENT_FETCH_ENABLED=true
PERFORMANCE__CACHE_TTL_SECONDS=3600
PERFORMANCE__MAX_CONCURRENT_REQUESTS=10
